# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# 서비스 URL (알림 메시지 링크에 사용)
NEXT_PUBLIC_SITE_URL=https://tataco.vercel.app

# Solapi (https://solapi.com)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=          # 등록된 발신번호 (예: 01012345678)

# 카카오 알림톡 채널 및 템플릿
KAKAO_CHANNEL_ID=              # pfId (비즈니스 채널 ID)
KAKAO_DAILY_TEMPLATE_ID=       # 매일 오전 9시 일일 요약 템플릿 ID
KAKAO_TASK_TEMPLATE_ID=        # 업무 등록 즉시 알림 템플릿 ID

# Vercel Cron 보안 토큰 (임의 문자열 생성 후 Vercel 환경변수에도 동일하게 설정)
CRON_SECRET=
